---
import LaunchLayout from '../../layouts/LaunchLayout.astro';
import LaunchWaitlistForm from '../../components/islands/LaunchWaitlistForm.tsx';
import CountdownTimer from '../../components/islands/CountdownTimer.tsx';

import BreathingQuiz from '../../components/islands/BreathingQuiz.tsx';
import BreathingChallenge from '../../components/islands/BreathingChallenge.tsx';
import LaunchHeroBackground from '../../components/LaunchHeroBackground.astro';
import LaunchFeaturesSticky from '../../components/LaunchFeaturesSticky.astro';



const sbUrl = import.meta.env.PUBLIC_SUPABASE_URL || '';
const sbKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY || '';

const frontmatter = {
  title: 'RespireLabs App Launch – Breathe Better, Sleep Better | Join the Waitlist',
  description: 'Join the waitlist for RespireLabs, the AI-powered breathing health app that detects mouth breathing and helps you sleep better. Limited early access.',
  lang: 'en',
  alternatePaths: { en: '/en/launch', de: '/de/launch', pl: '/pl/launch' },
  structuredData: {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "RespireLabs App Launch",
    "description": "Join the waitlist for RespireLabs, the AI-powered breathing health app.",
    "mainEntity": {
      "@type": "MobileApplication", "name": "RespireLabs", "operatingSystem": "iOS, Android",
      "applicationCategory": "HealthApplication",
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "EUR", "availability": "https://schema.org/PreOrder" }
    }
  }
};
---

<LaunchLayout frontmatter={frontmatter}>

  <!-- ============================================================== -->
  <!-- HERO (Full viewport)                                           -->
  <!-- ============================================================== -->
  <section class="section-full relative bg-brand-dark flex flex-col items-center justify-center overflow-hidden">
    <div class="absolute inset-0 bg-grid-pattern-dark opacity-30 pointer-events-none"></div>
    <div class="absolute top-1/3 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] md:w-[900px] md:h-[900px] pointer-events-none">
      <div class="absolute inset-0 bg-brand-blue/10 rounded-full blur-[150px] animate-[pulse_8s_ease-in-out_infinite]"></div>
      <div class="absolute top-1/3 left-1/4 w-[400px] h-[400px] md:w-[600px] md:h-[600px] bg-brand-yellow/5 rounded-full blur-[130px] animate-[pulse_12s_ease-in-out_infinite_alternate]"></div>
    </div>
    <LaunchHeroBackground />
    <div class="relative z-10 max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center flex flex-col items-center">
      <div class="inline-flex items-center space-x-2 glass-panel-dark px-4 py-1.5 rounded-full mb-5 md:mb-6 reveal hero-reveal">
        <span class="relative flex h-2 w-2"><span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-brand-blue opacity-75"></span><span class="relative inline-flex rounded-full h-2 w-2 bg-brand-blue"></span></span>
        <span class="text-[10px] md:text-xs font-montserrat font-bold tracking-widest uppercase text-white/70">Launching May 2026</span>
      </div>
      <h1 class="text-[2.75rem] sm:text-6xl md:text-7xl lg:text-8xl font-oddval font-bold text-white tracking-tighter leading-[0.9] mb-4 md:mb-5 reveal hero-reveal">
        Wake up<br/><span class="text-gradient">alive.</span>
      </h1>
      <p class="max-w-xl mx-auto text-base sm:text-lg font-montserrat font-light text-white/55 leading-relaxed mb-5 md:mb-7 reveal hero-reveal delay-100">
        You sleep 8 hours. You wake up exhausted. The problem isn't how long you sleep, it's how you breathe.
      </p>
      <div class="flex flex-wrap justify-center items-center gap-x-5 gap-y-1 mb-5 md:mb-7 reveal hero-reveal delay-100">
        <span class="flex items-center gap-1.5 text-xs font-montserrat text-white/40"><svg class="w-3.5 h-3.5 text-brand-blue" fill="currentColor" viewBox="0 0 20 20"><path d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" /></svg>AI-Powered Detection</span>
        <span class="flex items-center gap-1.5 text-xs font-montserrat text-white/40"><svg class="w-3.5 h-3.5 text-brand-blue" fill="currentColor" viewBox="0 0 20 20"><path d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" /></svg>iOS & Android</span>
      </div>
      <div class="flex flex-col sm:flex-row justify-center gap-3 sm:gap-4 mb-6 md:mb-8 w-full sm:w-auto reveal hero-reveal delay-200">
        <button type="button" class="cta-waitlist btn-shimmer inline-flex items-center justify-center rounded-full px-8 py-3.5 md:py-4 text-sm md:text-base font-semibold text-white transition-all duration-200 bg-[#206FF7] hover:bg-[#1a5cd4] hover:shadow-lg hover:shadow-[#206FF7]/25 active:scale-[0.98] font-montserrat">Join the Waitlist</button>
        <a href="#problem" class="inline-flex items-center justify-center rounded-full px-8 py-3.5 md:py-4 text-sm md:text-base font-semibold text-white/70 transition-all duration-200 border border-white/15 hover:bg-white/5 hover:text-white active:scale-[0.98] font-montserrat">See How It Works</a>
      </div>
      <div class="reveal hero-reveal delay-300">
        <p class="text-[10px] md:text-xs font-montserrat font-semibold tracking-widest uppercase text-white/30 mb-3">Launching in</p>
        <CountdownTimer client:visible targetDate="2026-05-01T00:00:00Z" lang="en" compact={true} />
      </div>
    </div>
    <div class="absolute bottom-4 md:bottom-6 left-1/2 -translate-x-1/2 animate-bounce opacity-30" aria-hidden="true">
      <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" /></svg>
    </div>
  </section>

  <!-- Inline waitlist form (hidden, revealed on CTA click) -->
  <div class="waitlist-inline hidden" data-form-for="hero">
    <section class="py-14 md:py-16 bg-brand-dark border-t border-white/5">
      <div class="max-w-lg mx-auto px-4">
        <div class="text-center mb-6"><h3 class="text-2xl font-oddval font-bold text-white mb-2">Be first. Breathe first.</h3><p class="text-sm font-montserrat text-white/50">Limited spots for our founding cohort.</p></div>
        <div class="bg-white rounded-[2rem] shadow-2xl p-6 md:p-8"><LaunchWaitlistForm client:visible lang="en" supabaseUrl={sbUrl} supabaseKey={sbKey} /></div>
      </div>
    </section>
  </div>

  <!-- ============================================================== -->
  <!-- PARTNERS / BACKED BY                                           -->
  <!-- ============================================================== -->
  <section class="py-8 md:py-12 bg-brand-dark relative z-20 border-t border-white/5">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 text-center reveal">
      <p class="text-xs md:text-sm font-montserrat font-bold tracking-widest uppercase text-white/40 mb-6 md:mb-8">Supported by & Featured in</p>
      <div class="flex flex-wrap justify-center items-center gap-10 md:gap-14 lg:gap-16">
        <img src="/partners/AWS_logo_Schrift-links_3Zeilig-e1733928366763.jpg" alt="AWS" class="h-10 md:h-12 object-contain opacity-50 hover:opacity-100 transition-opacity duration-300 invert mix-blend-screen" loading="lazy" />
        <img src="/partners/brutkasten.png" alt="Brutkasten" class="h-6 md:h-8 object-contain opacity-50 hover:opacity-100 transition-opacity duration-300 invert mix-blend-screen" loading="lazy" />
        <img src="/partners/logo-wko-tirol-768x235.jpg" alt="WKO Tirol" class="h-10 md:h-12 object-contain opacity-50 hover:opacity-100 transition-opacity duration-300 invert mix-blend-screen" loading="lazy" />
        <img src="/partners/tech-on.png" alt="Tech-ON" class="h-10 md:h-12 object-contain opacity-50 hover:opacity-100 transition-opacity duration-300" loading="lazy" />
        <img src="/partners/wolves-summit.png" alt="Wolves Summit" class="h-8 md:h-10 object-contain opacity-50 hover:opacity-100 transition-opacity duration-300" loading="lazy" />
      </div>
    </div>
  </section>

  <!-- ============================================================== -->
  <!-- THE PROBLEM (Full viewport)                                    -->
  <!-- ============================================================== -->
  <section id="problem" class="section-full bg-brand-dark relative overflow-hidden flex flex-col items-center justify-center">
    <div class="absolute inset-0 bg-grid-pattern-dark opacity-15 pointer-events-none"></div>
    <div class="relative z-10 max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl md:text-5xl font-oddval font-bold text-white text-center mb-12 md:mb-16 reveal">The silent epidemic.</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8 mb-12 md:mb-16">
        <div class="glass-panel-dark rounded-[2rem] p-8 text-center reveal delay-100">
          <div class="text-5xl md:text-6xl font-oddval font-bold text-brand-blue mb-3 gsap-counter" data-target="50" data-suffix="%">0%</div>
          <p class="text-sm font-montserrat text-white/60 font-light">of adults mouth-breathe during sleep</p>
        </div>
        <div class="glass-panel-dark rounded-[2rem] p-8 text-center reveal delay-200">
          <div class="text-5xl md:text-6xl font-oddval font-bold text-brand-yellow mb-3 gsap-counter" data-target="3" data-suffix="x">0x</div>
          <p class="text-sm font-montserrat text-white/60 font-light">more likely to wake exhausted</p>
        </div>
        <div class="glass-panel-dark rounded-[2rem] p-8 text-center reveal delay-300">
          <div class="text-5xl md:text-6xl font-oddval font-bold text-brand-blue mb-3 gsap-counter" data-target="80" data-suffix="%">0%</div>
          <p class="text-sm font-montserrat text-white/60 font-light">don't know they have a problem</p>
        </div>
      </div>
      <div class="max-w-3xl mx-auto text-center mb-10 reveal delay-400">
        <p class="text-xl md:text-2xl font-garamond italic text-brand-yellow leading-relaxed">"Most people have no idea their breathing is working against them every single night."</p>
      </div>
      <div class="text-center reveal delay-500">
        <button type="button" class="cta-waitlist btn-shimmer inline-flex items-center justify-center rounded-full px-8 py-4 text-base font-semibold text-white bg-[#206FF7] hover:bg-[#1a5cd4] hover:shadow-lg hover:shadow-[#206FF7]/25 active:scale-[0.98] font-montserrat transition-all">Join the Waitlist</button>
      </div>
    </div>
  </section>

  <!-- Inline waitlist form -->
  <div class="waitlist-inline hidden" data-form-for="problem">
    <section class="py-14 md:py-16 bg-brand-dark border-t border-white/5">
      <div class="max-w-lg mx-auto px-4">
        <div class="bg-white rounded-[2rem] shadow-2xl p-6 md:p-8"><LaunchWaitlistForm client:visible lang="en" supabaseUrl={sbUrl} supabaseKey={sbKey} /></div>
      </div>
    </section>
  </div>

  <!-- ============================================================== -->
  <!-- BREATHING QUIZ (Interactive micro-quiz)                        -->
  <!-- ============================================================== -->
  <section id="quiz-section" class="section-full bg-brand-dark relative overflow-hidden flex flex-col items-center justify-center">
    <div class="absolute inset-0 bg-grid-pattern-dark opacity-15 pointer-events-none"></div>
    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <BreathingQuiz client:visible lang="en" />
    </div>
  </section>

  <!-- Inline waitlist form -->
  <div class="waitlist-inline hidden" data-form-for="quiz">
    <section class="py-14 md:py-16 bg-brand-dark border-t border-white/5">
      <div class="max-w-lg mx-auto px-4">
        <div class="bg-white rounded-[2rem] shadow-2xl p-6 md:p-8"><LaunchWaitlistForm client:visible lang="en" supabaseUrl={sbUrl} supabaseKey={sbKey} /></div>
      </div>
    </section>
  </div>

  <!-- ============================================================== -->
  <!-- PHONE SHOWCASE (Full viewport, Night-to-Dawn)                  -->
  <!-- ============================================================== -->
  <section id="phone-showcase" class="night-to-dawn-section relative" data-section="transition">
    <div class="night-to-dawn-pin section-full flex items-center justify-center">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <div class="phone-mockup mx-auto mb-8 md:mb-12">
          <div class="phone-frame"><div class="phone-notch"></div>
            <div class="phone-screen">
              <img src="/assets/app-screenshots/home-dashboard.webp" alt="RespireLabs home dashboard" class="phone-screenshot active" data-index="0" loading="lazy" width="750" height="1326" />
              <img src="/assets/app-screenshots/breathing-pattern.webp" alt="Breathing pattern analysis" class="phone-screenshot" data-index="1" loading="lazy" width="750" height="1279" />
              <img src="/assets/app-screenshots/achievements.webp" alt="Achievements and quick actions" class="phone-screenshot" data-index="2" loading="lazy" width="750" height="1286" />
              <img src="/assets/app-screenshots/breathing-analysis.webp" alt="Real-time breathing analysis" class="phone-screenshot" data-index="3" loading="lazy" width="750" height="1303" />
            </div>
          </div>
        </div>
        <div class="dawn-text opacity-0">
          <h2 class="text-4xl md:text-6xl lg:text-7xl font-oddval font-bold tracking-tight mb-4">Meet <span class="text-gradient">RespireLabs.</span></h2>
          <p class="text-lg md:text-xl font-montserrat font-light max-w-2xl mx-auto" style="color:#6B7280">Your breathing, tracked. Your habits, transformed.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================== -->
  <!-- BREATHING CHALLENGE (30-second interactive)                    -->
  <!-- ============================================================== -->
  <section id="challenge-section" class="section-full bg-[#F7F7F9] flex flex-col items-center justify-center">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <BreathingChallenge client:visible lang="en" />
    </div>
  </section>

  <!-- Inline waitlist form -->
  <div class="waitlist-inline hidden" data-form-for="challenge">
    <section class="py-14 md:py-16 bg-[#F7F7F9] border-t border-brand-light/40">
      <div class="max-w-lg mx-auto px-4">
        <div class="bg-white rounded-[2rem] shadow-2xl p-6 md:p-8"><LaunchWaitlistForm client:visible lang="en" supabaseUrl={sbUrl} supabaseKey={sbKey} /></div>
      </div>
    </section>
  </div>

  <!-- ============================================================== -->
  <!-- FEATURES (Sticky Scroll)                                       -->
  <!-- ============================================================== -->
  <LaunchFeaturesSticky lang="en" />

  <!-- Inline waitlist form -->
  <div class="waitlist-inline hidden" data-form-for="features">
    <section class="py-14 md:py-16 bg-[#F7F7F9]">
      <div class="max-w-lg mx-auto px-4">
        <div class="bg-white rounded-[2rem] shadow-2xl p-6 md:p-8"><LaunchWaitlistForm client:visible lang="en" supabaseUrl={sbUrl} supabaseKey={sbKey} /></div>
      </div>
    </section>
  </div>

  <!-- ============================================================== -->
  <!-- FOUNDING MEMBER PERKS                                          -->
  <!-- ============================================================== -->
  <section class="section-full bg-brand-dark relative overflow-hidden flex flex-col items-center justify-center">
    <div class="absolute inset-0 bg-grid-pattern-dark opacity-15 pointer-events-none"></div>
    <div class="relative z-10 max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10 md:mb-14 reveal">
        <h2 class="text-3xl md:text-5xl font-oddval font-bold text-white mb-4">Be a Founding Member.</h2>
        <p class="text-base md:text-lg font-montserrat text-white/50 font-light">Exclusive perks for early waitlist members.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-4 md:gap-5 mb-6 reveal">
        <!-- Perk 1 -->
        <div class="glass-panel-dark rounded-[1.5rem] p-6 text-center">
          <div class="w-12 h-12 mx-auto mb-3 rounded-full bg-brand-yellow/15 flex items-center justify-center">
            <img src="/assets/icons/respire-labs-icons_tape.svg" alt="" class="w-6 h-6" loading="lazy" />
          </div>
          <h3 class="text-sm font-oddval font-bold text-white mb-1">Free Smart Tape</h3>
          <p class="text-xs font-montserrat text-white/40 font-light">Sample kit shipped to you</p>
        </div>
        <!-- Perk 2 -->
        <div class="glass-panel-dark rounded-[1.5rem] p-6 text-center">
          <div class="w-12 h-12 mx-auto mb-3 rounded-full bg-brand-yellow/15 flex items-center justify-center">
            <svg class="w-6 h-6 text-brand-yellow" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.568 3H5.25A2.25 2.25 0 003 5.25v4.318c0 .597.237 1.17.659 1.591l9.581 9.581c.699.699 1.78.872 2.607.33a18.095 18.095 0 005.223-5.223c.542-.827.369-1.908-.33-2.607L11.16 3.66A2.25 2.25 0 009.568 3z" /><path stroke-linecap="round" stroke-linejoin="round" d="M6 6h.008v.008H6V6z" /></svg>
          </div>
          <h3 class="text-sm font-oddval font-bold text-white mb-1">50% Off Year 1</h3>
          <p class="text-xs font-montserrat text-white/40 font-light">Locked-in founding price</p>
        </div>
        <!-- Perk 3 -->
        <div class="glass-panel-dark rounded-[1.5rem] p-6 text-center">
          <div class="w-12 h-12 mx-auto mb-3 rounded-full bg-brand-yellow/15 flex items-center justify-center">
            <svg class="w-6 h-6 text-brand-yellow" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" /></svg>
          </div>
          <h3 class="text-sm font-oddval font-bold text-white mb-1">Priority Access</h3>
          <p class="text-xs font-montserrat text-white/40 font-light">First to get the app</p>
        </div>
        <!-- Perk 4 -->
        <div class="glass-panel-dark rounded-[1.5rem] p-6 text-center">
          <div class="w-12 h-12 mx-auto mb-3 rounded-full bg-brand-yellow/15 flex items-center justify-center">
            <svg class="w-6 h-6 text-brand-yellow" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M20.25 8.511c.884.284 1.5 1.128 1.5 2.097v4.286c0 1.136-.847 2.1-1.98 2.193-.34.027-.68.052-1.02.072v3.091l-3-3c-1.354 0-2.694-.055-4.02-.163a2.115 2.115 0 01-.825-.242m9.345-8.334a2.126 2.126 0 00-.476-.095 48.64 48.64 0 00-8.048 0c-1.131.094-1.976 1.057-1.976 2.192v4.286c0 .837.46 1.58 1.155 1.951m9.345-8.334V6.637c0-1.621-1.152-3.026-2.76-3.235A48.455 48.455 0 0011.25 3c-2.115 0-4.198.137-6.24.402-1.608.209-2.76 1.614-2.76 3.235v6.226c0 1.621 1.152 3.026 2.76 3.235.577.075 1.157.14 1.74.194V21l4.155-4.155" /></svg>
          </div>
          <h3 class="text-sm font-oddval font-bold text-white mb-1">Founder Chat</h3>
          <p class="text-xs font-montserrat text-white/40 font-light">Direct line to the team</p>
        </div>
        <!-- Perk 5 -->
        <div class="glass-panel-dark rounded-[1.5rem] p-6 text-center">
          <div class="w-12 h-12 mx-auto mb-3 rounded-full bg-brand-yellow/15 flex items-center justify-center">
            <svg class="w-6 h-6 text-brand-yellow" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 6.75V15m6-6v8.25m.503 3.498l4.875-2.437c.381-.19.622-.58.622-1.006V4.82c0-.836-.88-1.38-1.628-1.006l-3.869 1.934c-.317.159-.69.159-1.006 0L9.503 3.252a1.125 1.125 0 00-1.006 0L3.622 5.689C3.24 5.88 3 6.27 3 6.695V19.18c0 .836.88 1.38 1.628 1.006l3.869-1.934c.317-.159.69-.159 1.006 0l4.994 2.497c.317.158.69.158 1.006 0z" /></svg>
          </div>
          <h3 class="text-sm font-oddval font-bold text-white mb-1">Shape the Roadmap</h3>
          <p class="text-xs font-montserrat text-white/40 font-light">Vote on features</p>
        </div>
      </div>
      <div class="text-center reveal">
        <button type="button" class="cta-waitlist btn-shimmer inline-flex items-center justify-center rounded-full px-8 py-4 text-base font-semibold text-white bg-[#206FF7] hover:bg-[#1a5cd4] hover:shadow-lg hover:shadow-[#206FF7]/25 active:scale-[0.98] font-montserrat transition-all">Claim Your Spot</button>
      </div>
    </div>
  </section>

  <!-- Inline waitlist form -->
  <div class="waitlist-inline hidden" data-form-for="perks">
    <section class="py-14 md:py-16 bg-brand-dark border-t border-white/5">
      <div class="max-w-lg mx-auto px-4">
        <div class="text-center mb-6"><h3 class="text-2xl font-oddval font-bold text-white mb-2">Be first. Breathe first.</h3><p class="text-sm font-montserrat text-white/50">Limited spots for our founding cohort.</p></div>
        <div class="bg-white rounded-[2rem] shadow-2xl p-6 md:p-8"><LaunchWaitlistForm client:visible lang="en" supabaseUrl={sbUrl} supabaseKey={sbKey} /></div>
      </div>
    </section>
  </div>

  <!-- ============================================================== -->
  <!-- HOW IT WORKS (Full viewport)                                   -->
  <!-- ============================================================== -->
  <section class="section-full bg-[#F7F7F9] flex flex-col items-center justify-center overflow-y-auto">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16">
      <div class="text-center mb-10 md:mb-14 reveal"><h2 class="text-3xl md:text-5xl font-oddval font-bold text-brand-dark mb-4">Three steps to better breathing.</h2></div>
      <div class="space-y-12 md:space-y-20">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12 items-center reveal">
          <div class="order-2 md:order-1">
            <div class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-brand-blue text-white font-oddval font-bold mb-3">1</div>
            <h3 class="text-xl font-oddval font-bold text-brand-dark mb-2">Download the app</h3>
            <p class="font-montserrat text-brand-grey font-light text-sm">Available on iOS and Android. Set up in under a minute.</p>
          </div>
          <div class="order-1 md:order-2 flex justify-center"><div class="phone-mockup-small"><div class="phone-frame-small"><img src="/assets/app-screenshots/home-dashboard.webp" alt="App home" class="w-full h-full object-contain object-top rounded-[1rem]" loading="lazy" /></div></div></div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12 items-center reveal">
