<style>
  /* Each section fills the viewport */
  .section-full {
    min-height: 100dvh;
  }

  /* Particle dots */
  .particle { position: absolute; width: 3px; height: 3px; background: rgba(255,255,255,0.3); border-radius: 50%; animation: twinkle 3s ease-in-out infinite alternate; }
  @keyframes twinkle { 0% { opacity: 0.1; transform: scale(0.8); } 100% { opacity: 0.5; transform: scale(1.2); } }

  /* Phone mockups */
  .phone-mockup { width: 280px; max-width: 100%; } @media (min-width: 768px) { .phone-mockup { width: 320px; } }
  .phone-frame { position: relative; background: #1a1a1c; border-radius: 3rem; padding: 12px; box-shadow: 0 25px 50px -12px rgba(0,0,0,0.5), inset 0 1px 0 rgba(255,255,255,0.1); }
  .phone-notch { position: absolute; top: 12px; left: 50%; transform: translateX(-50%); width: 100px; height: 28px; background: #1a1a1c; border-radius: 0 0 1rem 1rem; z-index: 10; }
  .phone-screen { position: relative; border-radius: 2.2rem; overflow: hidden; aspect-ratio: 9/16; background: #f5f5f7; }
  .phone-screenshot { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; object-position: top; opacity: 0; transition: opacity 0.6s ease; }
  .phone-screenshot.active { opacity: 1; }
  .phone-mockup-small { width: 180px; max-width: 100%; }
  .phone-frame-small { background: #f0f0f2; border-radius: 1.5rem; padding: 6px; box-shadow: 0 10px 25px -5px rgba(0,0,0,0.1); overflow: hidden; aspect-ratio: 9/16; }
  .phone-mockup-tiny { width: 120px; max-width: 100%; }

  /* Night-to-dawn */
  .night-to-dawn-section { background: #0A0A0B; min-height: 100dvh; }
  .dawn-text h2 { color: #0A0A0B; }
  .gsap-counter { font-variant-numeric: tabular-nums; }

  @media (prefers-reduced-motion: reduce) { .particle { animation: none; opacity: 0.3; } .phone-screenshot { transition: none; } }
</style>

<script>
  // CTA buttons reveal the nearest following waitlist-inline form
  function initCTAForms() {
    document.querySelectorAll('.cta-waitlist').forEach(btn => {
      btn.addEventListener('click', () => {
        // Find the closest section parent, then the next sibling .waitlist-inline
        const section = btn.closest('section') || btn.closest('.section-full');
        if (!section) return;
        const formWrapper = section.nextElementSibling?.classList.contains('waitlist-inline')
          ? section.nextElementSibling
          : section.parentElement?.nextElementSibling?.classList.contains('waitlist-inline')
            ? section.parentElement.nextElementSibling
            : null;
        if (!formWrapper) return;

        // Toggle: if already visible, hide it
        if (!formWrapper.classList.contains('hidden')) {
          formWrapper.classList.add('hidden');
          return;
        }

        // Hide all other open forms
        document.querySelectorAll('.waitlist-inline:not(.hidden)').forEach(f => f.classList.add('hidden'));

        // Show this form
        formWrapper.classList.remove('hidden');
        setTimeout(() => formWrapper.scrollIntoView({ behavior: 'smooth', block: 'start' }), 50);
      });
    });
  }
  initCTAForms();
  document.addEventListener('astro:after-swap', initCTAForms);
</script>

<script>
  async function initNightToDawn() {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      const section = document.querySelector('.night-to-dawn-section') as HTMLElement;
      if (section) { section.style.background = '#FAFAFA'; const dt = section.querySelector('.dawn-text') as HTMLElement; if (dt) dt.style.opacity = '1'; }
      return;
    }
    const { gsap } = await import('gsap'); const { ScrollTrigger } = await import('gsap/ScrollTrigger'); gsap.registerPlugin(ScrollTrigger);
    const section = document.querySelector('.night-to-dawn-section') as HTMLElement; const pinTarget = document.querySelector('.night-to-dawn-pin') as HTMLElement;
    const screenshots = document.querySelectorAll('.phone-screenshot'); const dawnText = document.querySelector('.dawn-text') as HTMLElement; const phoneMockup = document.querySelector('.phone-mockup') as HTMLElement;
    if (!section || !pinTarget || !screenshots.length) return;
    const tl = gsap.timeline({ scrollTrigger: { trigger: section, start: 'top top', end: '+=300%', pin: pinTarget, scrub: 1, anticipatePin: 1 } });
    tl.fromTo(phoneMockup, { y: 80, opacity: 0 }, { y: 0, opacity: 1, duration: 0.25 }, 0);
    tl.to(section, { backgroundColor: '#FAFAFA', duration: 0.5, ease: 'none' }, 0.25);
    const pf = document.querySelector('.phone-frame') as HTMLElement;
    if (pf) tl.to(pf, { backgroundColor: '#e5e5e7', boxShadow: '0 25px 50px -12px rgba(0,0,0,0.15), inset 0 1px 0 rgba(255,255,255,0.5)', duration: 0.5 }, 0.25);
    const st = [0.2, 0.4, 0.55, 0.7];
    screenshots.forEach((s, i) => { if (i === 0) tl.to(s, { opacity: 0, duration: 0.12 }, st[1]); if (i > 0) { tl.to(s, { opacity: 1, duration: 0.12 }, st[i]); if (i < screenshots.length - 1) tl.to(s, { opacity: 0, duration: 0.12 }, st[i + 1]); } });
    tl.to(dawnText, { opacity: 1, y: 0, duration: 0.25 }, 0.75);
  }
  document.addEventListener('DOMContentLoaded', initNightToDawn);
  document.addEventListener('astro:after-swap', initNightToDawn);
</script>
