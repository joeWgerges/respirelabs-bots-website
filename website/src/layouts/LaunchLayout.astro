---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title?: string;
  description?: string;
  lang?: string;
  structuredData?: object;
  alternatePaths?: { en?: string; de?: string; pl?: string };
  frontmatter?: any;
}

const {
  frontmatter,
  title = frontmatter?.title || 'RespireLabs',
  description = frontmatter?.description || '',
  lang = frontmatter?.lang || 'en',
  structuredData = frontmatter?.structuredData,
  alternatePaths
} = Astro.props;

const siteUrl = 'https://app.respirelabs.com';
const altPaths = alternatePaths || frontmatter?.alternatePaths;
const enPath = altPaths?.en || '/en/launch';
const dePath = altPaths?.de || '/de/launch';
const plPath = altPaths?.pl || '/pl/launch';

const currentLang = (lang as string) || 'en';
const allLangs = ['en', 'de', 'pl'] as const;
const langFlags: Record<string, string> = { en: '🇬🇧', de: '🇩🇪', pl: '🇵🇱' };
const langPaths: Record<string, string> = { en: enPath, de: dePath, pl: plPath };

const waitlistLabels: Record<string, string> = { en: 'Join Waitlist', de: 'Warteliste', pl: 'Dolacz do listy' };
const waitlistLabel = waitlistLabels[currentLang] || waitlistLabels.en;

const disclaimerText: Record<string, string> = {
  en: 'RespireLabs is a wellness product. It does not diagnose, treat, cure, or prevent any disease. If you suspect a sleep or breathing disorder, consult a qualified clinician.',
  de: 'RespireLabs ist ein Wellnessprodukt. Es diagnostiziert, behandelt, heilt oder verhindert keine Krankheiten. Bei Verdacht auf eine Schlaf- oder Atemstorung wenden Sie sich an einen qualifizierten Arzt.',
  pl: 'RespireLabs to produkt wellness. Nie diagnozuje, nie leczy, nie zapobiega zadnym chorobom. W przypadku podejrzenia zaburzen snu lub oddychania skonsultuj sie z lekarzem.',
};
const disclaimer = disclaimerText[currentLang] || disclaimerText.en;

const copyrightText: Record<string, string> = {
  en: `© ${new Date().getFullYear()} RespireLabs GmbH. All rights reserved.`,
  de: `© ${new Date().getFullYear()} RespireLabs GmbH. Alle Rechte vorbehalten.`,
  pl: `© ${new Date().getFullYear()} RespireLabs GmbH. Wszelkie prawa zastrzezone.`,
};

const privacyLabel: Record<string, string> = { en: 'Privacy', de: 'Datenschutz', pl: 'Prywatnosc' };

const privacyNotice: Record<string, { title: string; body: string }> = {
  en: {
    title: 'Privacy Notice',
    body: `<p class="mb-3">When you join the waitlist, we collect your <strong>email address</strong>, <strong>first name</strong>, and optional preferences (interest area, how you heard about us). This data is stored securely on EU-hosted servers (Supabase, Ireland region) and is used solely to:</p>
<ul class="list-disc pl-5 mb-3 space-y-1"><li>Send you updates about the RespireLabs app launch</li><li>Provide early access when the app is ready</li><li>Improve our pre-launch communication</li></ul>
<p class="mb-3">We do <strong>not</strong> sell, share, or transfer your data to third parties for marketing purposes. You can request deletion of your data at any time by emailing <a href="mailto:hello@respirelabs.com" class="text-[#206FF7] hover:underline">hello@respirelabs.com</a>.</p>
<p class="mb-3"><strong>Legal basis:</strong> Consent (Art. 6(1)(a) GDPR). You may withdraw consent at any time.</p>
<p><strong>Data controller:</strong> RespireLabs GmbH. Contact: <a href="mailto:hello@respirelabs.com" class="text-[#206FF7] hover:underline">hello@respirelabs.com</a></p>`,
  },
  de: {
    title: 'Datenschutzhinweis',
    body: `<p class="mb-3">Wenn du dich auf die Warteliste eintraegst, erfassen wir deine <strong>E-Mail-Adresse</strong>, deinen <strong>Vornamen</strong> und optionale Angaben (Interessengebiet, wie du von uns erfahren hast). Diese Daten werden sicher auf EU-Servern gespeichert (Supabase, Region Irland) und dienen ausschliesslich dazu:</p>
<ul class="list-disc pl-5 mb-3 space-y-1"><li>Dir Updates zum RespireLabs-App-Launch zu senden</li><li>Dir fruehzeitigen Zugang zu ermoeglichen</li><li>Unsere Kommunikation vor dem Launch zu verbessern</li></ul>
<p class="mb-3">Wir <strong>verkaufen, teilen oder uebertragen</strong> deine Daten nicht an Dritte zu Marketingzwecken. Du kannst die Loeschung deiner Daten jederzeit per E-Mail an <a href="mailto:hello@respirelabs.com" class="text-[#206FF7] hover:underline">hello@respirelabs.com</a> anfordern.</p>
<p class="mb-3"><strong>Rechtsgrundlage:</strong> Einwilligung (Art. 6 Abs. 1 lit. a DSGVO). Du kannst deine Einwilligung jederzeit widerrufen.</p>
<p><strong>Verantwortlicher:</strong> RespireLabs GmbH. Kontakt: <a href="mailto:hello@respirelabs.com" class="text-[#206FF7] hover:underline">hello@respirelabs.com</a></p>`,
  },
  pl: {
    title: 'Informacja o prywatnosci',
    body: `<p class="mb-3">Zapisujac sie na liste oczekujacych, zbieramy Twoj <strong>adres e-mail</strong>, <strong>imie</strong> oraz opcjonalne preferencje (obszar zainteresowania, skad o nas wiesz). Dane sa przechowywane bezpiecznie na serwerach w UE (Supabase, region Irlandia) i sluza wylacznie do:</p>
<ul class="list-disc pl-5 mb-3 space-y-1"><li>Wysylania aktualizacji o premierze aplikacji RespireLabs</li><li>Zapewnienia wczesnego dostepu gdy aplikacja bedzie gotowa</li><li>Ulepszania naszej komunikacji przed premiera</li></ul>
<p class="mb-3"><strong>Nie</strong> sprzedajemy, nie udostepniamy ani nie przekazujemy Twoich danych osobom trzecim w celach marketingowych. Mozesz zadac usuniecia danych w dowolnym momencie, pisac na <a href="mailto:hello@respirelabs.com" class="text-[#206FF7] hover:underline">hello@respirelabs.com</a>.</p>
<p class="mb-3"><strong>Podstawa prawna:</strong> Zgoda (art. 6 ust. 1 lit. a RODO). Mozesz wycofac zgode w dowolnym momencie.</p>
<p><strong>Administrator danych:</strong> RespireLabs GmbH. Kontakt: <a href="mailto:hello@respirelabs.com" class="text-[#206FF7] hover:underline">hello@respirelabs.com</a></p>`,
  },
};
const pNotice = privacyNotice[currentLang] || privacyNotice.en;
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/assets/logo/respire-labs-symbol_blue-symbol.png" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0A0A0B" />

    <link rel="alternate" hreflang="en" href={`${siteUrl}${enPath}`} />
    <link rel="alternate" hreflang="de" href={`${siteUrl}${dePath}`} />
    <link rel="alternate" hreflang="pl" href={`${siteUrl}${plPath}`} />
    <link rel="alternate" hreflang="x-default" href={`${siteUrl}${enPath}`} />
    <link rel="canonical" href={`${siteUrl}${Astro.url.pathname}`} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={`${siteUrl}${Astro.url.pathname}`} />
    <meta property="og:image" content={`${siteUrl}/assets/logo/respire-labs-logo_primary-logo.png`} />
    <meta property="og:locale" content={lang === 'de' ? 'de_DE' : lang === 'pl' ? 'pl_PL' : 'en_US'} />
    <meta property="og:site_name" content="RespireLabs" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    {structuredData && (
      <script type="application/ld+json" is:inline set:html={JSON.stringify(structuredData)} />
    )}
    <script type="application/ld+json" is:inline set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "RespireLabs",
      "url": "https://respirelabs.com",
      "logo": `${siteUrl}/assets/logo/respire-labs-logo_primary-logo.png`
    })} />
    <ClientRouter />
  </head>
  <body class="antialiased selection:bg-brand-blue selection:text-white flex flex-col min-h-screen relative overflow-x-hidden bg-brand-dark">

    <!-- STANDALONE HEADER: Logo + Language + CTA only -->
    <header class="fixed top-0 w-full z-50 transition-all duration-500 border-b border-transparent" id="main-header">
      <div class="absolute inset-0 bg-brand-dark/80 backdrop-blur-xl -z-10 transition-opacity duration-500 opacity-0" id="header-bg"></div>
      <div class="max-w-[88rem] mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center h-16 md:h-20 transition-all duration-500" id="header-container">
          <!-- Logo -->
          <a href={`/${currentLang}/launch`} class="flex-shrink-0 flex items-center group rounded-lg p-1" aria-label="RespireLabs">
            <img class="h-7 md:h-8 w-auto transition-transform duration-500 ease-out group-hover:scale-105" src="/assets/logo/respire-labs-logo_white-on-colour-logo.png" alt="RespireLabs" />
          </a>

          <!-- Right: Lang switcher + CTA -->
          <div class="flex items-center space-x-3 lg:space-x-4">
            <!-- Language pills (compact) -->
            <div class="hidden sm:flex items-center gap-1" role="group" aria-label="Language">
              {allLangs.map((l) => (
                <a
                  href={langPaths[l]}
                  class={`flex items-center gap-1 px-3 py-1.5 rounded-full text-xs font-semibold font-montserrat uppercase tracking-wide transition-all duration-200 ${
                    l === currentLang
                      ? 'bg-white/15 text-white'
                      : 'text-white/50 hover:text-white/80 hover:bg-white/5'
                  }`}
                  aria-current={l === currentLang ? 'page' : undefined}
                >
                  <span class="text-sm leading-none">{langFlags[l]}</span>
                  <span>{l.toUpperCase()}</span>
                </a>
              ))}
            </div>
            <!-- CTA (opens modal) -->
            <button id="header-waitlist-btn" type="button" class="bg-[#206FF7] text-white hover:bg-[#1a5cd4] hover:scale-[1.02] hover:shadow-[0_8px_20px_rgba(32,111,247,0.3)] font-montserrat text-sm font-semibold py-2 px-6 rounded-full transition-all duration-300 whitespace-nowrap">
              {waitlistLabel}
            </button>
          </div>
        </div>
      </div>
    </header>

    <main id="main-content" class="flex-grow outline-none" tabindex="-1" transition:animate="fade">
      <slot />
    </main>

    <!-- STICKY BOTTOM WAITLIST BAR -->
    <div id="sticky-waitlist-bar" class="fixed bottom-0 left-0 right-0 z-40 transform translate-y-full transition-transform duration-500 ease-out hidden md:block">
      <div class="bg-white/10 backdrop-blur-xl border-t border-white/20 px-4 py-2 shadow-[0_-10px_40px_rgba(0,0,0,0.3)]">
        <div class="max-w-5xl mx-auto flex flex-row justify-between items-center gap-3">
          <p class="text-xs font-montserrat font-medium text-white/80">Founding Member spots are limited. <span class="text-white/50 hidden sm:inline">Claim your perks before they're gone.</span></p>
          <button id="sticky-waitlist-bar-btn" type="button" class="cta-waitlist btn-shimmer magnetic-btn inline-flex items-center justify-center rounded-full px-5 py-2 text-xs font-semibold text-white bg-[#206FF7] hover:bg-[#1a5cd4] transition-all whitespace-nowrap shadow-[0_0_20px_rgba(32,111,247,0.4)]">Claim Yours</button>
        </div>
      </div>
    </div>

    <!-- STANDALONE FOOTER: Minimal -->
    <footer class="bg-brand-dark border-t border-white/10 py-12">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Disclaimer -->
        <div class="rounded-xl bg-white/5 border border-white/10 p-4 mb-8">
          <p class="text-xs font-montserrat text-white/40 leading-relaxed">{disclaimer}</p>
        </div>
        <!-- Bottom row -->
        <div class="flex flex-col sm:flex-row justify-between items-center gap-4">
          <p class="text-xs font-montserrat text-white/30">{copyrightText[currentLang]}</p>
          <div class="flex items-center gap-4">
            <button id="footer-privacy-btn" type="button" class="text-xs font-montserrat text-white/40 hover:text-white/70 transition-colors cursor-pointer">{privacyLabel[currentLang]}</button>
            <span class="text-white/10">|</span>
            <a href="mailto:hello@respirelabs.com" class="text-xs font-montserrat text-white/40 hover:text-white/70 transition-colors">hello@respirelabs.com</a>
          </div>
        </div>
      </div>
    </footer>

    <!-- WAITLIST MODAL (opened by header CTA) -->
    <div id="waitlist-modal" class="fixed inset-0 z-[60] hidden" role="dialog" aria-modal="true" aria-label="Join Waitlist">
      <!-- Backdrop -->
      <div id="waitlist-modal-backdrop" class="absolute inset-0 bg-black/60 backdrop-blur-sm opacity-0 transition-opacity duration-300"></div>
      <!-- Panel -->
      <div class="absolute inset-0 flex items-center justify-center p-4">
        <div id="waitlist-modal-panel" class="relative bg-white rounded-[2rem] shadow-2xl w-full max-w-lg max-h-[90vh] overflow-y-auto p-6 md:p-8 scale-95 opacity-0 transition-all duration-300">
          <!-- Close button -->
          <button id="waitlist-modal-close" type="button" class="absolute top-4 right-4 text-[#6B7280] hover:text-[#0A0A0B] transition-colors z-10" aria-label="Close">
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
          </button>
          <!-- Modal form slot (filled by page) -->
          <div id="waitlist-modal-content">
            <slot name="modal-form" />
          </div>
        </div>
      </div>
    </div>

    <!-- PRIVACY MODAL -->
    <div id="privacy-modal" class="fixed inset-0 z-[60] hidden" role="dialog" aria-modal="true" aria-label={pNotice.title}>
      <div id="privacy-modal-backdrop" class="absolute inset-0 bg-black/60 backdrop-blur-sm opacity-0 transition-opacity duration-300"></div>
      <div class="absolute inset-0 flex items-center justify-center p-4">
        <div id="privacy-modal-panel" class="relative bg-white rounded-[2rem] shadow-2xl w-full max-w-lg max-h-[90vh] overflow-y-auto p-6 md:p-8 scale-95 opacity-0 transition-all duration-300">
          <button id="privacy-modal-close" type="button" class="absolute top-4 right-4 text-[#6B7280] hover:text-[#0A0A0B] transition-colors z-10" aria-label="Close">
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
          </button>
          <h3 class="text-xl font-bold mb-4 pr-8" style="font-family:var(--font-oddval);color:#0A0A0B">{pNotice.title}</h3>
          <div class="text-sm font-montserrat text-[#6B7280] leading-relaxed" set:html={pNotice.body} />
        </div>
      </div>
    </div>

    <!-- Scroll effects for header and sticky bar -->
    <script>
      function initLaunchHeader() {
        const header = document.getElementById('main-header');
        const headerBg = document.getElementById('header-bg');
        const container = document.getElementById('header-container');
        const stickyBar = document.getElementById('sticky-waitlist-bar');

        window.addEventListener('scroll', () => {
          // Header logic
          if (window.scrollY > 20) {
            header?.classList.add('border-white/[0.05]');
            header?.classList.remove('border-transparent');
            headerBg?.classList.remove('opacity-0');
            headerBg?.classList.add('opacity-100');
            if (container) { container.classList.remove('md:h-20'); container.classList.add('md:h-16'); }
          } else {
            header?.classList.remove('border-white/[0.05]');
            header?.classList.add('border-transparent');
            headerBg?.classList.add('opacity-0');
            headerBg?.classList.remove('opacity-100');
            if (container) { container.classList.add('md:h-20'); container.classList.remove('md:h-16'); }
          }

          // Sticky Bar logic
          if (window.scrollY > window.innerHeight * 0.8) {
            stickyBar?.classList.remove('translate-y-full');
          } else {
            stickyBar?.classList.add('translate-y-full');
          }
        }, { passive: true });

        // Magnetic button logic
        document.querySelectorAll('.magnetic-btn').forEach(btn => {
          btn.addEventListener('mousemove', (e: any) => {
            const rect = btn.getBoundingClientRect();
            const x = e.clientX - rect.left - rect.width / 2;
            const y = e.clientY - rect.top - rect.height / 2;
            (btn as HTMLElement).style.transform = `translate(${x * 0.2}px, ${y * 0.2}px)`;
          });
          btn.addEventListener('mouseleave', () => {
            (btn as HTMLElement).style.transform = 'translate(0px, 0px)';
          });
        });
      }
      initLaunchHeader();
      document.addEventListener('astro:after-swap', initLaunchHeader);
    </script>

    <!-- Modal logic (header CTA opens popup) -->
    <script>
      function initWaitlist() {
        const modal = document.getElementById('waitlist-modal');
        const backdrop = document.getElementById('waitlist-modal-backdrop');
        const panel = document.getElementById('waitlist-modal-panel');
        const closeBtn = document.getElementById('waitlist-modal-close');
        const headerBtn = document.getElementById('header-waitlist-btn');

        function openModal() {
          if (!modal) return;
          modal.classList.remove('hidden');
          document.body.style.overflow = 'hidden';
          requestAnimationFrame(() => {
            backdrop?.classList.remove('opacity-0');
            backdrop?.classList.add('opacity-100');
            panel?.classList.remove('scale-95', 'opacity-0');
            panel?.classList.add('scale-100', 'opacity-100');
          });
        }

        function closeModal() {
          if (!modal) return;
          backdrop?.classList.add('opacity-0');
          backdrop?.classList.remove('opacity-100');
          panel?.classList.add('scale-95', 'opacity-0');
          panel?.classList.remove('scale-100', 'opacity-100');
          document.body.style.overflow = '';
          setTimeout(() => modal.classList.add('hidden'), 300);
        }

        headerBtn?.addEventListener('click', openModal);
        closeBtn?.addEventListener('click', closeModal);
        backdrop?.addEventListener('click', closeModal);
        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape' && modal && !modal.classList.contains('hidden')) closeModal();
        });
      }
      initWaitlist();
      document.addEventListener('astro:after-swap', initWaitlist);
    </script>

    <!-- Privacy modal logic -->
    <script>
      function initPrivacyModal() {
        const modal = document.getElementById('privacy-modal');
        const backdrop = document.getElementById('privacy-modal-backdrop');
        const panel = document.getElementById('privacy-modal-panel');
        const closeBtn = document.getElementById('privacy-modal-close');
        const footerBtn = document.getElementById('footer-privacy-btn');

        function openPrivacy() {
          if (!modal) return;
          modal.classList.remove('hidden');
          document.body.style.overflow = 'hidden';
          requestAnimationFrame(() => {
            backdrop?.classList.remove('opacity-0');
            backdrop?.classList.add('opacity-100');
            panel?.classList.remove('scale-95', 'opacity-0');
            panel?.classList.add('scale-100', 'opacity-100');
          });
        }

        function closePrivacy() {
          if (!modal) return;
          backdrop?.classList.add('opacity-0');
          backdrop?.classList.remove('opacity-100');
          panel?.classList.add('scale-95', 'opacity-0');
          panel?.classList.remove('scale-100', 'opacity-100');
          document.body.style.overflow = '';
          setTimeout(() => modal.classList.add('hidden'), 300);
        }

        footerBtn?.addEventListener('click', openPrivacy);
        closeBtn?.addEventListener('click', closePrivacy);
        backdrop?.addEventListener('click', closePrivacy);
        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape' && modal && !modal.classList.contains('hidden')) closePrivacy();
        });

        // Allow form privacy links to open this modal
        document.addEventListener('click', (e) => {
          const target = e.target as HTMLElement;
          if (target.closest('[data-open-privacy]')) {
            e.preventDefault();
            openPrivacy();
          }
        });
      }
      initPrivacyModal();
      document.addEventListener('astro:after-swap', initPrivacyModal);
    </script>

    <!-- CSS reveal animations -->
    <script>
      const observer = new IntersectionObserver((entries, obs) => {
        entries.forEach(entry => { if (entry.isIntersecting) { entry.target.classList.add('active'); obs.unobserve(entry.target); } });
      }, { threshold: 0.1 });

      const initCSSAnimations = () => {
        document.querySelectorAll('.reveal:not(.active), .reveal-left:not(.active), .reveal-right:not(.active)').forEach(el => observer.observe(el));
        setTimeout(() => { document.querySelectorAll('.hero-reveal').forEach(el => el.classList.add('active')); }, 50);
      };
      initCSSAnimations();
      document.addEventListener('astro:after-swap', initCSSAnimations);
    </script>

    <!-- GSAP animations (lazy-loaded) -->
    <script>
      let gsapInitialized = false;
      async function initGSAPAnimations() {
        try {
          const { initScrollAnimations, cleanupAnimations } = await import('../lib/animations');
          if (gsapInitialized) cleanupAnimations();
          initScrollAnimations();
          gsapInitialized = true;
        } catch (err) {
          console.warn('[RespireLabs] GSAP failed:', err);
        }
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', initGSAPAnimations);
      else initGSAPAnimations();
      document.addEventListener('astro:after-swap', initGSAPAnimations);
      document.addEventListener('astro:before-swap', async () => {
        if (gsapInitialized) { const { cleanupAnimations } = await import('../lib/animations'); cleanupAnimations(); }
      });
    </script>
  </body>
</html>
